STYLE_SETTINGS_BODY_CLASSES=mod-windows is-frameless is-hidden-frameless obsidian-app theme-light show-inline-title show-view-header is-maximized is-focused css-settings-manager additional-editor-css minimal-theme colorful-headings colorful-frame colorful-active minimal-focus-mode links-int-on links-ext-on full-width-media img-grid minimal-folding minimal-line-nums minimal-readable AT-row minimal-dark labeled-nav chart-default-width table-default-width img-default-width iframe-default-width map-default-width minimal-default-light minimal-light toggle-floating-toc-header-color default-outline-style callouts-default trim-cols checkbox-circle pdf-seamless-on pdf-invert-dark pdf-blend-light sidebar-tabs-default tab-names-off ribbon-hidden maximize-tables-off tabs-default tab-stack-top minimal-tab-title-hover minimal-default-dark
USE_FULL_RESOLUTION_IMAGES=false
